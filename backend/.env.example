# Copy this file to `backend/.env` and fill in your own values.
# `backend/.env` is git-ignored — keep real keys out of the repo.

# ---------- LLM judge ----------
# Choose one provider. The backend reads JUDGE_PROVIDER and only requires that
# provider's key.
JUDGE_PROVIDER=deepseek                              # deepseek | openai | anthropic | gemini

# DeepSeek (default, OpenAI-compatible). Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat                         # or deepseek-reasoner / deepseek-v4-pro

# OpenAI (set JUDGE_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (set JUDGE_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Google Gemini (set JUDGE_PROVIDER=gemini to use)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---------- Naming round-trip ----------
# pubchem_stout      = PubChem REST first, STOUT fallback (recommended)
# pubchem            = PubChem only
# stout_local        = Local STOUT (requires Python 3.9 + TF 2.10 side env)
# stub               = Skip SMILES→IUPAC (round-trip will be partial)
IUPAC_PROVIDER=pubchem_stout

OPSIN_PROVIDER=opsin_web                             # opsin_web | py2opsin
OPSIN_WEB_URL=https://www.ebi.ac.uk/opsin/ws

# ---------- Confidence weights (must sum ~1.0) ----------
CONFIDENCE_WEIGHT_ROUND_TRIP=0.3
CONFIDENCE_WEIGHT_JUDGE=0.3
CONFIDENCE_WEIGHT_VERIFY=0.4
